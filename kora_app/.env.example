# ════════════════════════════════════════════════════════════════
#  KORA App Flutter — Variables de entorno
#  Copia este archivo como .env dentro de kora_app/
# ════════════════════════════════════════════════════════════════

# URL del backend para Android Emulator (apunta al host del emulador)
API_URL=http://10.0.2.2:8000

# URL del backend para Web / desktop
API_URL_WEB=http://localhost:8000

# URL WebSocket para Android Emulator
WS_URL=ws://10.0.2.2:8000

# URL WebSocket para Web / desktop
WS_URL_WEB=ws://localhost:8000
