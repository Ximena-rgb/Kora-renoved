# =============================================================================
# KORA — university-social-platform
# .env.example  |  Copiar a .env y completar los valores reales
# =============================================================================

# ── Django ────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-segura-de-50-caracteres
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Base de Datos ─────────────────────────────────────────────────
DB_NAME=kora_db
DB_USER=kora_user
DB_PASSWORD=kora_password
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Dominio universitario permitido ──────────────────────────────
# Solo correos con este dominio pueden registrarse
# Ejemplo: unal.edu.co, eafit.edu.co, udem.edu.co
ALLOWED_EMAIL_DOMAIN=unal.edu.co

# ── Firebase Auth (MFA / TOTP) ────────────────────────────────────
# Ruta al archivo JSON de credenciales de Firebase Admin SDK
# Dejar vacío para deshabilitar Firebase (solo JWT propio)
FIREBASE_CREDENTIALS_PATH=

# ── AI — Gemini API ───────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Storage ───────────────────────────────────────────────────────
MEDIA_ROOT=/storage/uploads
LOG_FILE=/storage/logs/api-core.log

# ── Service-to-service auth (workers internos) ───────────────────
# Token compartido entre api-core ↔ api-media ↔ worker-ai
SERVICE_TOKEN=genera-un-uuid-aqui

# ── URLs internas (Docker network) ───────────────────────────────
API_CORE_INTERNAL_URL=http://api-core:8000

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=kora_grafana_2024
