# ════════════════════════════════════════════════════════════════
#  KORA — Variables de entorno del backend
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas el .env real a git.
# ════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=*

# ── PostgreSQL ────────────────────────────────────────────────────
DB_NAME=kora_db
DB_USER=kora_user
DB_PASSWORD=cambia_esta_password
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Dominio institucional ─────────────────────────────────────────
# Solo usuarios con este dominio podrán registrarse.
# Déjalo vacío para permitir cualquier correo Google (solo en dev).
ALLOWED_EMAIL_DOMAIN=tuuniversidad.edu.co

# ── Firebase Admin SDK ────────────────────────────────────────────
# Ruta al archivo JSON de credenciales de Firebase Admin.
# Descárgalo desde: Firebase Console → Configuración del proyecto
#   → Cuentas de servicio → Generar nueva clave privada
# Coloca el archivo en: apps/api-core/src/firebase-credentials.json
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Firebase Web API Key (solo debug) ─────────────────────────────
# Requerida solo para el endpoint /auth/debug/login/ (DEBUG=True).
# La encuentras en: Firebase Console → Configuración del proyecto → General
FIREBASE_WEB_API_KEY=tu_web_api_key_de_firebase

# ── JWT ───────────────────────────────────────────────────────────
JWT_SIGNING_KEY=cambia-esto-por-otra-clave-secreta-para-jwt

# ── MFA ───────────────────────────────────────────────────────────
MFA_ISSUER_NAME=Kora University

# ── Storage ───────────────────────────────────────────────────────
MEDIA_ROOT=/storage/uploads
LOG_FILE=/storage/logs/api-core.log

# ── Token interno entre microservicios ───────────────────────────
SERVICE_TOKEN=cambia-este-token-interno
API_CORE_INTERNAL_URL=http://api-core:8000

# ── Superusuario dev (solo cuando DEBUG=True) ─────────────────────
DJANGO_SUPERUSER_EMAIL=admin@kora.dev
DJANGO_SUPERUSER_PASSWORD=cambia_esta_password_admin

# ── AI (opcional) ────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Ollama (IA local, opcional) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Monitoreo ────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=cambia_esta_password_grafana
